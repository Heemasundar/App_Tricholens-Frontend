<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Status Bar Space -->
    <View
        android:layout_width="match_parent"
        android:layout_height="24dp" />

    <!-- Header with Profile -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome"
                android:textSize="14sp"
                android:textColor="#666666" />

            <TextView
                android:layout_width="115dp"
                android:layout_height="34dp"
                android:text=""
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Main Scalp Image -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <ImageView
            android:id="@+id/scalpImageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/scalp"
            android:scaleType="centerCrop"
            android:contentDescription="Scalp Image" />
    </androidx.cardview.widget.CardView>

    <!-- Action Buttons -->
    <Button
        android:id="@+id/selectAgainButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Select again"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/background__pink"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/diagnoseButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Diagnose"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:background="@drawable/green_background"/>


</LinearLayout>
